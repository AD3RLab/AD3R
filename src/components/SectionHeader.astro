---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  linkHref?: string;
  linkLabel?: string;
}

const { title, description, eyebrow, linkHref, linkLabel } = Astro.props;
---

<div class="section-header">
  <div>
    {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p class="section-description">{description}</p>}
  </div>
  {linkHref && linkLabel && (
    <a class="text-link" href={linkHref}>{linkLabel}</a>
  )}
</div>
