---
import Badge from "./Badge.astro";

interface Props {
  status: string;
  label?: string;
}

const { status, label } = Astro.props;

const toneMap: Record<string, "primary" | "neutral" | "success" | "warning" | "danger"> = {
  active: "success",
  maintenance: "primary",
  planning: "warning",
  archived: "neutral",
  tracking: "primary",
  researching: "warning",
  validating: "success",
  completed: "neutral",
  paused: "danger",
  added: "success",
  changed: "primary",
  fixed: "warning",
  removed: "danger",
  todo: "warning",
  doing: "primary",
  done: "success"
};
---

<Badge label={label ?? status} variant={toneMap[status] ?? "neutral"} />
