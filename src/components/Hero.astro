---
interface ActionItem {
  label: string;
  href: string;
  kind?: "primary" | "secondary";
}

interface MetricItem {
  label: string;
  value: string;
}

interface Props {
  title: string;
  description: string;
  actions: ActionItem[];
  metrics?: MetricItem[];
  eyebrow?: string;
}

const { title, description, actions, metrics = [], eyebrow = "Research Team" } = Astro.props;
---

<section class="hero card surface-gradient">
  <div class="hero-copy">
    <p class="section-eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-description">{description}</p>
    <div class="hero-actions">
      {actions.map((action) => (
        <a class={action.kind === "secondary" ? "button ghost" : "button"} href={action.href}>{action.label}</a>
      ))}
    </div>
  </div>

  {metrics.length > 0 && (
    <div class="hero-metrics">
      {metrics.map((metric) => (
        <div class="metric-card">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
        </div>
      ))}
    </div>
  )}
</section>
