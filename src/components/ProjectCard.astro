---
import type { Project } from "../data/projects";
import Badge from "./Badge.astro";
import StatusBadge from "./StatusBadge.astro";
import { projectStatusLabels, formatDate } from "../utils/format";
import { withBase } from "../utils/links";

interface Props {
  project: Project;
  leaderName: string;
  memberNames: string[];
}

const { project, leaderName, memberNames } = Astro.props;
---

<article class="card project-card">
  {project.cover && <img src={withBase(project.cover)} alt={`${project.name} 封面`} class="project-cover" loading="lazy" />}
  <div class="project-card-body">
    <div class="card-heading split-wrap">
      <h3><a href={withBase(`/projects/${project.id}/`)}>{project.name}</a></h3>
      <StatusBadge status={project.status} label={projectStatusLabels[project.status]} />
    </div>
    <p>{project.summary}</p>
    <div class="meta-list">
      <span>当前版本：{project.version ?? "未发布"}</span>
      <span>负责人：{leaderName}</span>
      <span>相关成员：{memberNames.join(" / ")}</span>
      <span>最近更新：{formatDate(project.updatedAt)}</span>
    </div>
    <div class="tag-row compact">
      {project.techStack.map((item) => <Badge label={item} />)}
    </div>
    <div class="link-row">
      {project.repoUrl && <a class="text-link" href={project.repoUrl} target="_blank" rel="noreferrer">仓库</a>}
      {project.demoUrl && <a class="text-link" href={project.demoUrl} target="_blank" rel="noreferrer">Demo</a>}
    </div>
  </div>
</article>
