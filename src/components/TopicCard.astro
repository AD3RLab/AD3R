---
import type { ResearchTopic } from "../data/researchTopics";
import StatusBadge from "./StatusBadge.astro";
import Badge from "./Badge.astro";
import { topicPriorityLabels, topicStatusLabels, formatDate } from "../utils/format";
import { withBase } from "../utils/links";

interface Props {
  topic: ResearchTopic;
  memberNames: string[];
}

const { topic, memberNames } = Astro.props;
---

<article class="card topic-card">
  <div class="card-heading split-wrap">
    <h3><a href={withBase(`/topics/${topic.id}/`)}>{topic.title}</a></h3>
    <div class="anchor-row compact">
      <Badge label={`${topicPriorityLabels[topic.priority]}优先级`} variant="primary" />
      <StatusBadge status={topic.status} label={topicStatusLabels[topic.status]} />
    </div>
  </div>
  <p>{topic.background}</p>
  <div class="meta-list">
    <span>相关成员：{memberNames.join(" / ")}</span>
    <span>最近更新：{formatDate(topic.updatedAt)}</span>
  </div>
  <p class="muted">最近进展：{topic.progress}</p>
  <div class="tag-row compact">
    {topic.keywords.map((keyword) => <Badge label={keyword} />)}
  </div>
  <div class="link-row">
    <a class="text-link" href={withBase(`/topics/${topic.id}/`)}>查看课题详情</a>
  </div>
</article>
