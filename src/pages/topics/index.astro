---
import Layout from "../../components/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TopicCard from "../../components/TopicCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { researchTopics } from "../../data/researchTopics";
import { members } from "../../data/members";
import { topicStatusLabels } from "../../utils/format";

const statuses = ["tracking", "researching", "validating", "completed", "paused"] as const;
const memberMap = Object.fromEntries(members.map((member) => [member.id, member]));
---

<Layout title="课题追踪" description="展示 AD3R 当前正在追踪、研究、验证、完成或暂停的关键课题。">
  <section class="page-hero card surface-gradient">
    <p class="section-eyebrow">Topics</p>
    <h1>课题追踪</h1>
    <p>页面按课题状态分组，帮助团队和访客快速判断哪些方向仍在调研、哪些已经进入验证或完成收敛。</p>
  </section>

  <section class="stat-grid">
    {statuses.map((status) => (
      <article class="stat-card card">
        <strong>{researchTopics.filter((topic) => topic.status === status).length}</strong>
        <span>{topicStatusLabels[status]}</span>
      </article>
    ))}
  </section>

  {statuses.map((status) => {
    const list = researchTopics.filter((topic) => topic.status === status);
    return (
      <section>
        <SectionHeader title={topicStatusLabels[status]} description={`共 ${list.length} 个课题`} />
        {list.length > 0 ? (
          <div class="grid grid-2">
            {list.map((topic) => <TopicCard topic={topic} memberNames={topic.memberIds.map((id) => memberMap[id]?.name ?? id)} />)}
          </div>
        ) : (
          <EmptyState title="暂无课题" description="当前状态下还没有示例课题，可在数据文件中继续补充。" />
        )}
      </section>
    );
  })}
</Layout>
