---
import Layout from "../../components/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TopicCard from "../../components/TopicCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { researchTopics } from "../../data/researchTopics";
import { members } from "../../data/members";
import { topicPriorityLabels } from "../../utils/format";

const priorities = ["urgent", "high", "medium", "low"] as const;
const memberMap = Object.fromEntries(members.map((member) => [member.id, member]));
---

<Layout title="课题追踪" description="展示 AD3R 当前正在追踪、研究、验证、完成或暂停的关键课题。">
  <section class="page-hero card surface-gradient">
    <p class="section-eyebrow">Topics</p>
    <h1>课题追踪</h1>
    <p>页面按课题优先级展示当前关注事项，便于先看最紧急和最关键的方向，再逐步查看中长期课题。</p>
  </section>

  <section class="stat-grid">
    {priorities.map((priority) => (
      <article class="stat-card card">
        <strong>{researchTopics.filter((topic) => topic.priority === priority).length}</strong>
        <span>{topicPriorityLabels[priority]}优先级</span>
      </article>
    ))}
  </section>

  {priorities.map((priority) => {
    const list = researchTopics
      .filter((topic) => topic.priority === priority)
      .sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt));
    return (
      <section>
        <SectionHeader title={`${topicPriorityLabels[priority]}优先级`} description={`共 ${list.length} 个课题`} />
        {list.length > 0 ? (
          <div class="grid grid-2">
            {list.map((topic) => <TopicCard topic={topic} memberNames={topic.memberIds.map((id) => memberMap[id]?.name ?? id)} />)}
          </div>
        ) : (
          <EmptyState title="暂无课题" description="当前状态下还没有示例课题，可在数据文件中继续补充。" />
        )}
      </section>
    );
  })}
</Layout>
