---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { members } from "../../data/members";
import { projects } from "../../data/projects";
import { researchTopics } from "../../data/researchTopics";
import { formatDate, topicStatusLabels } from "../../utils/format";
import { withBase } from "../../utils/links";

const newsEntries = (await getCollection("news")).sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
const changelogEntries = (await getCollection("changelog")).sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const memberMap = Object.fromEntries(members.map((member) => [member.id, member]));
const roadmapStatusLabels = {
  todo: "待启动",
  doing: "进行中",
  done: "已完成"
} as const;

const reviewStats = {
  activeProjects: projects.filter((project) => project.status === "active").length,
  doingMilestones: projects.flatMap((project) => project.roadmap).filter((item) => item.status === "doing").length,
  validatingTopics: researchTopics.filter((topic) => ["researching", "validating"].includes(topic.status)).length,
  recentItems: newsEntries.slice(0, 3).length + changelogEntries.slice(0, 3).length
};

const upcomingMilestones = projects
  .flatMap((project) =>
    project.roadmap
      .filter((item) => item.status !== "done")
      .map((item) => ({
        ...item,
        projectId: project.id,
        projectName: project.name,
        leaderName: memberMap[project.leaderId]?.name ?? "未设置"
      }))
  )
  .sort((a, b) => {
    const dateA = a.targetDate ? +new Date(a.targetDate) : Number.MAX_SAFE_INTEGER;
    const dateB = b.targetDate ? +new Date(b.targetDate) : Number.MAX_SAFE_INTEGER;
    return dateA - dateB;
  });

const projectBoard = projects
  .map((project) => ({
    id: project.id,
    name: project.name,
    leaderName: memberMap[project.leaderId]?.name ?? "未设置",
    currentMilestone: project.roadmap.find((item) => item.status === "doing") ?? project.roadmap.find((item) => item.status === "todo"),
    latestUpdate: [...project.updates].sort((a, b) => +new Date(b.date) - +new Date(a.date))[0]
  }))
  .sort((a, b) => {
    const aHasDoing = a.currentMilestone?.status === "doing" ? 0 : 1;
    const bHasDoing = b.currentMilestone?.status === "doing" ? 0 : 1;
    return aHasDoing - bHasDoing;
  });

const topicActions = researchTopics
  .filter((topic) => ["tracking", "researching", "validating"].includes(topic.status))
  .flatMap((topic) =>
    topic.nextSteps.map((step) => ({
      id: topic.id,
      title: topic.title,
      status: topic.status,
      updatedAt: topic.updatedAt,
      step,
      memberNames: topic.memberIds.map((id) => memberMap[id]?.name ?? id).join("、")
    }))
  )
  .slice(0, 10);

const topicBoard = researchTopics
  .map((topic) => ({
    ...topic,
    memberNames: topic.memberIds.map((id) => memberMap[id]?.name ?? id).join("、"),
    nextStep: topic.nextSteps[0] ?? "待补充"
  }))
  .sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt));

const recentFeed = [
  ...newsEntries.slice(0, 3).map((entry) => ({
    type: "动态",
    date: entry.data.date,
    title: entry.data.title,
    summary: entry.data.summary
  })),
  ...changelogEntries.slice(0, 3).map((entry) => ({
    type: "更新",
    date: entry.data.date,
    title: `${entry.data.version} · ${entry.data.summary}`,
    summary: entry.body
  }))
]
  .sort((a, b) => +new Date(b.date) - +new Date(a.date))
  .slice(0, 6);
---

<Layout title="组会面板" description="汇总 AD3R 当前项目推进、课题状态、里程碑与近期更新。">
  <section class="page-hero card surface-gradient section-panel">
    <p class="section-eyebrow">Review</p>
    <h1>组会面板</h1>
    <p>汇总项目推进、课题状态、近期里程碑与最新更新，方便统一查看当前研发进展。</p>
    <div class="anchor-row">
      <a class="text-chip" href="#review-topics">课题总表</a>
      <a class="text-chip" href="#review-actions">待跟进事项</a>
      <a class="text-chip" href="#review-projects">项目推进</a>
      <a class="text-chip" href="#review-milestones">里程碑</a>
      <a class="text-chip" href="#review-updates">近期更新</a>
    </div>
  </section>

  <section class="stat-grid meeting-grid section-panel section-panel-alt">
    <article class="stat-card card"><strong>{reviewStats.activeProjects}</strong><span>活跃项目</span></article>
    <article class="stat-card card"><strong>{reviewStats.doingMilestones}</strong><span>进行中里程碑</span></article>
    <article class="stat-card card"><strong>{reviewStats.validatingTopics}</strong><span>重点课题推进中</span></article>
    <article class="stat-card card"><strong>{reviewStats.recentItems}</strong><span>近期动态与更新</span></article>
  </section>

  <section class="section-panel" id="review-topics">
    <article class="card">
      <SectionHeader
        title="课题总表"
        description="按最近更新时间展示课题状态、下一步与详情入口。"
        linkHref={withBase("/topics/")}
        linkLabel="查看全部课题"
      />
      <div class="table-wrap scroll-panel">
        <table class="data-table">
          <thead>
            <tr>
              <th>课题</th>
              <th>状态</th>
              <th>相关成员</th>
              <th>下一步</th>
              <th>更新时间</th>
            </tr>
          </thead>
          <tbody>
            {topicBoard.map((topic) => (
              <tr>
                <td>
                  <a class="table-link" href={withBase(`/topics/${topic.id}/`)}>{topic.title}</a>
                </td>
                <td>{topicStatusLabels[topic.status]}</td>
                <td>{topic.memberNames}</td>
                <td>{topic.nextStep}</td>
                <td>{formatDate(topic.updatedAt)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>
  </section>

  <section class="section-panel" id="review-actions">
    <article class="card">
      <SectionHeader
        title="待跟进事项"
        description="列出当前课题仍需推进的关键动作与相关成员。"
        linkHref={withBase("/topics/")}
        linkLabel="查看课题页"
      />
      <div class="content-stack compact-stack scroll-panel tight">
        {topicActions.map((item) => (
          <article class="action-card review-action-item">
            <div class="card-heading split-wrap">
              <h3><a href={withBase(`/topics/${item.id}/`)}>{item.title}</a></h3>
              <span class="text-chip">{topicStatusLabels[item.status]}</span>
            </div>
            <p>{item.step}</p>
            <div class="meta-list">
              <span>相关成员：{item.memberNames}</span>
              <span>{formatDate(item.updatedAt)}</span>
            </div>
          </article>
        ))}
      </div>
    </article>
  </section>

  <section class="section-panel" id="review-projects">
    <SectionHeader title="项目推进总表" description="汇总当前项目负责人、里程碑与最近更新。"/>
    <div class="table-wrap card scroll-panel tight">
      <table class="data-table">
        <thead>
          <tr>
            <th>项目</th>
            <th>负责人</th>
            <th>当前里程碑</th>
            <th>目标时间</th>
            <th>最近更新</th>
          </tr>
        </thead>
        <tbody>
          {projectBoard.map((project) => (
            <tr>
              <td><a class="table-link" href={withBase(`/projects/${project.id}/`)}>{project.name}</a></td>
              <td>{project.leaderName}</td>
              <td>{project.currentMilestone?.title ?? "待补充"}</td>
              <td>{project.currentMilestone?.targetDate ? formatDate(project.currentMilestone.targetDate) : "待定"}</td>
              <td>{project.latestUpdate ? `${formatDate(project.latestUpdate.date)} · ${project.latestUpdate.title}` : "暂无更新"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section-panel section-panel-alt" id="review-milestones">
    <article class="card">
      <SectionHeader title="近期里程碑" description="按目标时间展示近期需要推进的里程碑节点。" />
      <div class="table-wrap scroll-panel tight">
        <table class="data-table">
          <thead>
            <tr>
              <th>项目</th>
              <th>里程碑</th>
              <th>状态</th>
              <th>负责人</th>
              <th>目标时间</th>
            </tr>
          </thead>
          <tbody>
            {upcomingMilestones.slice(0, 10).map((item) => (
              <tr>
                <td><a class="table-link" href={withBase(`/projects/${item.projectId}/`)}>{item.projectName}</a></td>
                <td>{item.title}</td>
                <td>{roadmapStatusLabels[item.status]}</td>
                <td>{item.leaderName}</td>
                <td>{item.targetDate ? formatDate(item.targetDate) : "待定"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>
  </section>

  <section class="section-panel section-panel-alt" id="review-updates">
    <article class="card">
      <SectionHeader title="近期动态与更新" description="汇总最近的团队动态与版本更新。" />
      <div class="timeline scroll-panel tight">
        {recentFeed.map((item) => (
          <article class="timeline-item">
            <div>
              <span class="timeline-dot"></span>
            </div>
            <div>
              <p class="muted">{item.type} · {formatDate(item.date)}</p>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </article>
  </section>
</Layout>
