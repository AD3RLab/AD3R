---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import MemberCard from "../components/MemberCard.astro";
import AchievementCard from "../components/AchievementCard.astro";
import TopicCard from "../components/TopicCard.astro";
import NewsCard from "../components/NewsCard.astro";
import { siteConfig } from "../data/site";
import { members } from "../data/members";
import { projects } from "../data/projects";
import { achievements } from "../data/achievements";
import { researchTopics } from "../data/researchTopics";
import { formatDate } from "../utils/format";
import { withBase } from "../utils/links";

const newsEntries = (await getCollection("news")).sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
const changelogEntries = (await getCollection("changelog")).sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const memberMap = Object.fromEntries(members.map((member) => [member.id, member]));
const featuredMembers = members.slice(0, 3);
const featuredProjects = [...projects].sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt)).slice(0, 3);
const featuredAchievements = [...achievements].sort((a, b) => +new Date(b.date) - +new Date(a.date)).slice(0, 3);
const featuredTopics = [...researchTopics].sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt)).slice(0, 3);
const activeProjectCount = projects.filter((project) => project.status === "active").length;
const roadmapStatusLabels = {
  todo: "待启动",
  doing: "进行中",
  done: "已完成"
} as const;
const meetingStats = {
  doingMilestones: projects.flatMap((project) => project.roadmap).filter((item) => item.status === "doing").length,
  todoMilestones: projects.flatMap((project) => project.roadmap).filter((item) => item.status === "todo").length,
  validatingTopics: researchTopics.filter((topic) => ["researching", "validating"].includes(topic.status)).length,
  recentUpdates: projects.flatMap((project) => project.updates).length
};
const upcomingMilestones = projects
  .flatMap((project) =>
    project.roadmap
      .filter((item) => item.status !== "done")
      .map((item) => ({
        ...item,
        projectName: project.name,
        leaderName: memberMap[project.leaderId]?.name ?? "未设置"
      }))
  )
  .sort((a, b) => {
    const dateA = a.targetDate ? +new Date(a.targetDate) : Number.MAX_SAFE_INTEGER;
    const dateB = b.targetDate ? +new Date(b.targetDate) : Number.MAX_SAFE_INTEGER;
    return dateA - dateB;
  })
  .slice(0, 6);
const projectFocusList = projects
  .map((project) => ({
    id: project.id,
    name: project.name,
    leaderName: memberMap[project.leaderId]?.name ?? "未设置",
    currentMilestone: project.roadmap.find((item) => item.status === "doing") ?? project.roadmap.find((item) => item.status === "todo"),
    latestUpdate: [...project.updates].sort((a, b) => +new Date(b.date) - +new Date(a.date))[0]
  }))
  .sort((a, b) => {
    const aHasDoing = a.currentMilestone?.status === "doing" ? 0 : 1;
    const bHasDoing = b.currentMilestone?.status === "doing" ? 0 : 1;
    return aHasDoing - bHasDoing;
  });
const topicActionList = researchTopics
  .filter((topic) => ["tracking", "researching", "validating"].includes(topic.status))
  .sort((a, b) => +new Date(b.updatedAt) - +new Date(a.updatedAt))
  .slice(0, 4);
const timeline = [
  ...newsEntries.slice(0, 3).map((entry) => ({
    date: entry.data.date,
    title: entry.data.title,
    summary: entry.data.summary,
    type: "动态"
  })),
  ...changelogEntries.slice(0, 3).map((entry) => ({
    date: entry.data.date,
    title: `${entry.data.version}  ${entry.data.summary}`,
    summary: entry.body,
    type: "更新"
  }))
].sort((a, b) => +new Date(b.date) - +new Date(a.date)).slice(0, 5);
---

<Layout>
  <Hero
    title={siteConfig.name}
    description={siteConfig.description}
    eyebrow={siteConfig.englishName}
    actions={[
      { label: "查看项目", href: withBase("/projects/") },
      { label: "查看团队成员", href: withBase("/members/"), kind: "secondary" }
    ]}
    metrics={[
      { label: "团队成员", value: `${members.length}` },
      { label: "活跃项目", value: `${activeProjectCount}` },
      { label: "成果总数", value: `${achievements.length}` },
      { label: "课题追踪", value: `${researchTopics.length}` }
    ]}
  />

  <section class="grid grid-2">
    <article class="card">
      <SectionHeader title="团队简介" eyebrow="Overview" />
      <p>{siteConfig.mission}</p>
      <p class="muted">团队主要面向 {siteConfig.audience.join("、")}，重点解决影子数据利用、稀有场景复现、仿真数据闭环和真实世界资产化等关键问题。</p>
    </article>
    <article class="card">
      <SectionHeader title="核心研究方向" eyebrow="Focus" />
      <div class="tag-row">
        {siteConfig.researchDirections.map((direction) => <span class="text-chip large">{direction}</span>)}
      </div>
    </article>
  </section>

  <section>
    <SectionHeader
      title="核心能力建设"
      description="围绕真实场景重建、3DGS 表达、动静态分离、尺度恢复、渲染接入和语义增强，持续建设面向自动驾驶的数据资产化能力。"
    />
    <div class="grid grid-3">
      {siteConfig.capabilities.map((item) => (
        <article class="card">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <SectionHeader
      title="组会总览"
      description="把项目推进、近期里程碑和课题状态集中到一个视图里，方便组会时快速核对整体节奏。"
    />
    <div class="stat-grid meeting-grid">
      <article class="stat-card card">
        <strong>{meetingStats.doingMilestones}</strong>
        <span>进行中里程碑</span>
      </article>
      <article class="stat-card card">
        <strong>{meetingStats.todoMilestones}</strong>
        <span>待排期里程碑</span>
      </article>
      <article class="stat-card card">
        <strong>{meetingStats.validatingTopics}</strong>
        <span>重点课题验证中</span>
      </article>
      <article class="stat-card card">
        <strong>{meetingStats.recentUpdates}</strong>
        <span>项目更新记录</span>
      </article>
    </div>
  </section>

  <section class="grid grid-sidebar">
    <article class="card">
      <SectionHeader
        title="近期里程碑"
        description="按目标时间排序，优先看当前进行中和接下来需要排期的里程碑。"
        linkHref={withBase("/projects/")}
        linkLabel="查看项目看板"
      />
      <div class="content-stack compact-stack">
        {upcomingMilestones.map((item) => (
          <article class="timeline-item compact">
            <div>
              <span class="timeline-dot"></span>
            </div>
            <div>
              <p class="muted">{item.projectName} · 负责人 {item.leaderName}</p>
              <h3>{item.title}</h3>
              <div class="meta-list">
                <span>{roadmapStatusLabels[item.status]}</span>
                <span>{item.targetDate ? formatDate(item.targetDate) : "待定"}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </article>

    <article class="card">
      <SectionHeader
        title="本次组会建议聚焦"
        description="优先同步正在推进的课题、待确认的下一步，以及需要跨角色配合的项目。"
      />
      <div class="content-stack compact-stack">
        {topicActionList.map((topic) => (
          <article class="meeting-focus-item">
            <div class="card-heading split-wrap">
              <h3>{topic.title}</h3>
              <span class="text-chip">{formatDate(topic.updatedAt)}</span>
            </div>
            <p>{topic.progress}</p>
            <ul class="detail-list compact-list">
              {topic.nextSteps.slice(0, 2).map((step) => <li>{step}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </article>
  </section>

  <section>
    <SectionHeader
      title="项目推进重点"
      description="每个项目展示当前推进项和最近更新，适合组会中快速过一遍整体规划。"
    />
    <div class="grid grid-3">
      {projectFocusList.map((project) => (
        <article class="card focus-card">
          <div class="card-heading split-wrap">
            <h3>{project.name}</h3>
            <a class="text-link" href={withBase(`/projects/${project.id}/`)}>查看详情</a>
          </div>
          <p class="muted">负责人：{project.leaderName}</p>
          {project.currentMilestone ? (
            <>
              <p><strong>当前里程碑：</strong>{project.currentMilestone.title}</p>
              <div class="meta-list">
                <span>{roadmapStatusLabels[project.currentMilestone.status]}</span>
                <span>{project.currentMilestone.targetDate ? formatDate(project.currentMilestone.targetDate) : "时间待定"}</span>
              </div>
            </>
          ) : (
            <p class="muted">当前尚未设置里程碑。</p>
          )}
          {project.latestUpdate && (
            <div class="focus-update">
              <p class="muted">最近更新 · {formatDate(project.latestUpdate.date)}</p>
              <p><strong>{project.latestUpdate.title}</strong></p>
              <p>{project.latestUpdate.content}</p>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <section>
    <SectionHeader
      title="重点产品与项目"
      description="围绕自动驾驶场景重建、3DGS 表达、场景编辑与导出渲染能力，持续建设可复用的技术资产。"
      linkHref={withBase("/projects/")}
      linkLabel="查看全部项目"
    />
    <div class="grid grid-3">
      {featuredProjects.map((project) => (
        <ProjectCard
          project={project}
          leaderName={memberMap[project.leaderId]?.name ?? "未设置"}
          memberNames={project.memberIds.map((id) => memberMap[id]?.name ?? id)}
        />
      ))}
    </div>
  </section>

  <section>
    <SectionHeader
      title="最新动态"
      description="记录团队在自动驾驶场景重建、导出渲染与场景资产化方向上的阶段性进展。"
      linkHref={withBase("/news/")}
      linkLabel="查看全部动态"
    />
    <div class="grid grid-3">
      {newsEntries.slice(0, 3).map((entry) => <NewsCard entry={entry} />)}
    </div>
  </section>

  <section>
    <SectionHeader
      title="代表性成果"
      description="展示技术综述、报告、软件原型、专利申请、演示系统与阶段性工程成果。"
      linkHref={withBase("/achievements/")}
      linkLabel="查看全部成果"
    />
    <div class="grid grid-3">
      {featuredAchievements.map((achievement) => <AchievementCard achievement={achievement} />)}
    </div>
  </section>

  <section>
    <SectionHeader
      title="当前追踪课题"
      description="覆盖追踪、研究、验证、完成和暂停等不同阶段，帮助团队持续观察 3D 场景资产化中的关键问题。"
      linkHref={withBase("/topics/")}
      linkLabel="查看全部课题"
    />
    <div class="grid grid-3">
      {featuredTopics.map((topic) => (
        <TopicCard topic={topic} memberNames={topic.memberIds.map((id) => memberMap[id]?.name ?? id)} />
      ))}
    </div>
  </section>

  <section>
    <SectionHeader title="核心成员" description="成员覆盖 3DGS、SLAM、深度估计、产品规划、UE 渲染与技术美术等关键角色。" linkHref={withBase("/members/")} linkLabel="查看全部成员" />
    <div class="grid grid-3">
      {featuredMembers.map((member) => <MemberCard member={member} achievementCount={member.achievementIds.length} />)}
    </div>
  </section>

  <section>
    <SectionHeader title="最新时间线" description="用时间线快速浏览团队最近的重要动态、迭代节点和版本更新。" />
    <div class="timeline card">
      {timeline.map((item) => (
        <article class="timeline-item">
          <div>
            <span class="timeline-dot"></span>
          </div>
          <div>
            <p class="muted">{item.type}  {formatDate(item.date)}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
