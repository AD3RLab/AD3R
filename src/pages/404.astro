---
import Layout from "../components/Layout.astro";
import { withBase } from "../utils/links";
---

<Layout title="页面未找到" description="你访问的页面不存在或已经移动。">
  <section class="card empty-state page-hero">
    <p class="section-eyebrow">404</p>
    <h1>页面未找到</h1>
    <p>你访问的内容可能已经移动，或者当前链接有误。</p>
    <a class="button" href={withBase("/")}>返回首页</a>
  </section>
</Layout>
