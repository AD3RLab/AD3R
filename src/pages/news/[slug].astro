---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import { formatDate } from "../../utils/format";

export async function getStaticPaths() {
  const newsEntries = await getCollection("news");
  return newsEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <article class="news-article card">
    <p class="section-eyebrow">News Detail</p>
    <h1>{entry.data.title}</h1>
    <div class="meta-list article-meta">
      <span>日期：{formatDate(entry.data.date)}</span>
      <span>作者：{entry.data.author}</span>
      <span>标签：{entry.data.tags.join(" / ")}</span>
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>
